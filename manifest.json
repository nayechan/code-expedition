{
  "manifest_version": 3,
  "name": "Co-Te Expedition",
  "description": "알고리즘 스터디 문제 풀이 타이머 & 확인",
  "version": "1.0",
  "action": {
    "default_popup": "index.html",
    "default_icon": "icons/48.png"
  },
  "icons": {
    "16": "icons/16.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  },
  "host_permissions": [
    "https://solved.ac/*",
    "https://docs.google.com/*",
    "https://script.google.com/*",
    "https://script.googleusercontent.com/*"
  ]
}
